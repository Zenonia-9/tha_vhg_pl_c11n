<?xml version="1.0" encoding="UTF-8" ?>
<templates>
    <t t-name="tha_vhg_pl_c11n.AccountReportFilterVHGPartnerLedgerAccount" t-inherit="account_reports.AccountReportFiltersCustomizable" t-inherit-mode="extension">
        <xpath expr="//div[@id='filter_partner']" position="after">
            <t t-if="'vhg_pl_account_filter' in controller.cachedFilterOptions">
                <div id="filter_vhg_pl_account" class="filter_vhg_account">
                    <Dropdown menuClass="'account_report_filter vhg_account'">
                        <button class="btn btn-secondary">
                            <i class="fa fa-folder-open me-1"/>COA
                        </button>

                        <t t-set-slot="content">
                            <div class="dropdown-item gap-2 align-items-center">
                                <label>Accounts</label>
                                <MultiRecordSelector t-props="getMultiRecordSelectorProps('account.account', 'account_ids')" domain="['|', ['account_type', '=', 'asset_receivable'], ['account_type', '=', 'liability_payable']]"/>
                            </div>
                        </t>
                    </Dropdown>
                </div>
            </t>
        </xpath>
    </t>
</templates>
